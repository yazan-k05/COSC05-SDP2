# Global
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=180
MAX_MODEL_RETRIES=3

# Sensor Node (PC2)
SENSOR_BIND_HOST=0.0.0.0
SENSOR_BIND_PORT=8101
SENSOR_OLLAMA_BASE_URL=http://127.0.0.1:11434
SENSOR_MODEL_NAME=phi3.5
SENSOR_DDOS_MODEL_NAME=phi3.5
SENSOR_GPS_MODEL_NAME=phi3.5
SENSOR_FILTER_NODE_URL=http://192.168.1.10:8102
SENSOR_GLOBAL_MODEL_URL=http://127.0.0.1:8104
SENSOR_SUSPICIOUS_THRESHOLD=0.60

# Filter Node (Laptop RTX 3070)
FILTER_BIND_HOST=0.0.0.0
FILTER_BIND_PORT=8102
FILTER_OLLAMA_BASE_URL=http://127.0.0.1:11434
FILTER_MODEL_NAME=mistral:7b
FILTER_DDOS_MODEL_NAME=mistral:7b
FILTER_GPS_MODEL_NAME=mistral:7b
FILTER_BRAIN_NODE_URL=http://127.0.0.1:8103
FILTER_GLOBAL_MODEL_URL=http://127.0.0.1:8104
FILTER_MIN_RISK_TO_FORWARD=45

# Brain Node (Laptop CPU)
BRAIN_BIND_HOST=0.0.0.0
BRAIN_BIND_PORT=8103
BRAIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
BRAIN_MODEL_NAME=qwen2.5:32b
BRAIN_DDOS_MODEL_NAME=qwen2.5:32b
BRAIN_GPS_MODEL_NAME=qwen2.5:32b
BRAIN_GLOBAL_MODEL_URL=http://127.0.0.1:8104

# Orchestrator (Laptop)
ORCH_BIND_HOST=0.0.0.0
ORCH_BIND_PORT=8100
ORCH_SENSOR_NODE_URL=http://192.168.1.20:8101
ORCH_FILTER_NODE_URL=http://127.0.0.1:8102
ORCH_BRAIN_NODE_URL=http://127.0.0.1:8103
ORCH_GLOBAL_MODEL_URL=http://127.0.0.1:8104
ORCH_ALLOWED_ORIGINS=*
ORCH_WEBSOCKET_HEARTBEAT_SECONDS=8
ORCH_DDOS_ENABLED=true
ORCH_GPS_SPOOF_ENABLED=true

# Global Model (Federated Coordinator)
GLOBAL_BIND_HOST=0.0.0.0
GLOBAL_BIND_PORT=8104
GLOBAL_OLLAMA_BASE_URL=http://127.0.0.1:11434
GLOBAL_MODEL_NAME=mistral:7b
GLOBAL_ROUND_DURATION_SECONDS=30
GLOBAL_HISTORY_SIZE=40
GLOBAL_SENSOR_NODE_URL=http://127.0.0.1:8101
GLOBAL_FILTER_NODE_URL=http://127.0.0.1:8102
GLOBAL_BRAIN_NODE_URL=http://127.0.0.1:8103
GLOBAL_LEARNING_ENABLED=false
GLOBAL_AUTO_ROUNDS=false
GLOBAL_LEARNING_RATE=0.20
GLOBAL_MIN_SAMPLES_PER_NODE=8
GLOBAL_MAX_SAMPLES_PER_NODE=64
GLOBAL_AUTO_ROUND_INTERVAL_SECONDS=120

# Dedicated Panel App
PANEL_BIND_HOST=0.0.0.0
PANEL_BIND_PORT=8200
PANEL_ORCHESTRATOR_URL=http://127.0.0.1:8100
PANEL_GLOBAL_MODEL_URL=http://127.0.0.1:8104

# Federated Learning Panel
FEDLAB_BIND_HOST=0.0.0.0
FEDLAB_BIND_PORT=8300
FEDLAB_GLOBAL_MODEL_URL=http://127.0.0.1:8104
FEDLAB_ORCHESTRATOR_URL=http://127.0.0.1:8100

# SMTP Admin Alerts
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ids-alerts@localhost
SMTP_USE_TLS=true
ALERT_COOLDOWN_SECONDS=120
ALERT_MIN_SEVERITY=suspicious
